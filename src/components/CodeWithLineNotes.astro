---
type Notes = Record<number, string>;

interface Props {
  code: string;
  notes: Notes;
  language?: string;
}

const { code, notes } = Astro.props;
const lines = code.split("\n");
---

<style>
.code-block {
  background: #20252A;
  padding: 16px;
  border-radius: 8px;
  border: 1px solid #3B4147;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
    "Liberation Mono", "Courier New", monospace;
  font-size: 13px;
  line-height: 0.75;
  overflow-x: auto;
}

.code-group{
  margin-bottom: 8px;
}

.code-line {
  white-space: pre;
}

.code-line.has-note code{
  background: rgba(59,130,246,0.15);
  border-radius:4px;
}

.bubble {
  position: relative;

  display: inline-block;
  width: fit-content;
  max-width: 380px;

  margin: 13px 0 0px 12px;
  padding: 6px 6px;

  background: #1DA1F2;
  color: white;

  border-radius: 6px;

  font-size: 12px;

  word-break: keep-all;
}

.bubble::before{
  content:"";
  position:absolute;
  top:-5px;
  left:60px;

  border-left:6px solid transparent;
  border-right:6px solid transparent;
  border-bottom:6px solid #1DA1F2;
}

</style>

<div class="code-block">
{lines.map((line, index) => {
  const lineNumber = index + 1;
  const note = notes[lineNumber];

  return (
    <div class="code-group">
      <div class={`code-line ${note ? "has-note" : ""}`}>
        <code>{line}</code>
      </div>

      {note && (
        <div class="bubble">
          {note}
        </div>
      )}
    </div>
  );
})}
</div>